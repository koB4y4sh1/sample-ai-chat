# AG_UI_BASE_URL: URL of the AG-UI service.
# The Next.js BFF route forwards CopilotKit agent traffic to `${AG_UI_BASE_URL}/copilotkit`.
AG_UI_BASE_URL="http://127.0.0.1:8100"

# MCP_SERVER_URL: URL of the streamable HTTP MCP server used for MCP Apps.
MCP_SERVER_URL="http://127.0.0.1:8101/mcp"

# GOOGLE_MAPS_API_KEY: Google Maps JavaScript API browser key.
# You may also put this in the repository root .env.
GOOGLE_MAPS_API_KEY=""
