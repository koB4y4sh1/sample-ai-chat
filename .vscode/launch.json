{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FE: Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/web/src",
      "preLaunchTask": "dev:web",
      "sourceMaps": true
    },
    {
      "name": "BE: Agent",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/agent/src/main.py",
      "console": "integratedTerminal"
    }
  ]
}
