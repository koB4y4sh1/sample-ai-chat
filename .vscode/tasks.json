{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "install:js",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "install:py",
      "type": "shell",
      "command": "uv",
      "args": ["sync", "--all-packages", "--dev"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "dev:web",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "dev:web"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "zenith-dev-server",
        "pattern": [
          {
            "regexp": ".",
            "file": 0,
            "location": 1,
            "message": 0
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Server running on http://localhost:[0-9]+"
        }
      }
    },
    {
      "label": "format",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "format"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "lint"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "typecheck"],
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "check",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "check"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "pre-commit",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pre-commit", "run", "--all-files"],
      "group": "test",
      "problemMatcher": []
    }
  ]
}
